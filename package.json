{
  "name": "arma-attendance-web",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @arma-attendance/api dev",
    "dev:api": "pnpm --filter @arma-attendance/api dev",
    "dev:web": "pnpm --filter @arma-attendance/web dev",
    "fonts:aurebesh": "bash scripts/fetch-aurebeshaf-fonts.sh",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "smoke:local": "bash scripts/dev-smoke.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:status": "bash scripts/db-status.sh",
    "drizzle:check": "pnpm --filter @arma-attendance/api exec drizzle-kit check --config ../../drizzle.config.ts",
    "drizzle:boundary": "pnpm --filter @arma-attendance/api exec tsx ../../scripts/drizzle-boundary-check.ts",
    "db:backfill:attendance": "pnpm --filter @arma-attendance/api exec tsx src/scripts/backfillAttendance.ts",
    "db:backfill:scoreboard": "pnpm --filter @arma-attendance/api exec tsx src/scripts/backfillScoreboardStats.ts",
    "db:backfill:units": "pnpm --filter @arma-attendance/api exec tsx src/scripts/backfillUnits.ts",
    "admin:grant": "pnpm --filter @arma-attendance/api exec tsx ../../scripts/admin-grant.ts",
    "admin:list": "pnpm --filter @arma-attendance/api exec tsx ../../scripts/admin-list.ts",
    "smoke:db": "bash scripts/db-smoke.sh",
    "smoke:operations": "bash scripts/operations-smoke.sh",
    "smoke:operations:observability": "bash scripts/operations-observability-smoke.sh",
    "smoke:attendance": "bash scripts/normalized-attendance-smoke.sh",
    "smoke:scoreboard": "bash scripts/scoreboard-stats-smoke.sh",
    "smoke:battalions": "bash scripts/battalions-smoke.sh",
    "smoke:leaderboard": "bash scripts/leaderboard-smoke.sh",
    "smoke:cors": "bash scripts/cors-smoke.sh",
    "smoke:base44": "bash scripts/base44-token-smoke.sh",
    "smoke:base44:oauth": "bash scripts/base44-oauth-smoke.sh",
    "smoke:csrf": "bash scripts/csrf-smoke.sh",
    "smoke:dashboard": "bash scripts/dashboard-smoke.sh",
    "smoke:exports": "bash scripts/exports-smoke.sh",
    "smoke:data-quality": "bash scripts/data-quality-smoke.sh",
    "smoke:discord": "bash scripts/discord-smoke.sh",
    "smoke:auth": "bash scripts/auth-smoke.sh",
    "smoke:rbac": "bash scripts/rbac-smoke.sh",
    "release:check": "bash scripts/release-check.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
