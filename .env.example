NODE_ENV=production
APP_NAME=arma-attendance
APP_VERSION=0.1.0

HOST=0.0.0.0
PORT=3000

PUBLIC_BASE_URL=https://arma-stats.example.com

API_TOKEN=change-this-token
BOT_API_TOKEN=
LOG_LEVEL=info

DATABASE_URL=postgres://arma_attendance:change-me@localhost:5432/arma_attendance

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://arma-stats.example.com/auth/discord/callback
DISCORD_AUTH_ENABLED=true
DISCORD_AUTH_REQUIRE_GUILD=true
DISCORD_AUTH_CONFIG_PATH=./config/discord-guild-auth.json
DISCORD_AUTH_DEFAULT_FALLBACK_GUILD_IDS=1478100812818550845
DISCORD_AUTH_ALLOW_FALLBACK_GUILD_IDS=false
DISCORD_AUTH_REQUIRE_CONFIG_FILE=true
DISCORD_AUTH_RECONCILE_ON_LOGIN=true
DISCORD_AUTH_RECONCILE_STALE_AFTER_MINUTES=240
DISCORD_AUTH_ALLOW_OAUTH_REFRESH_STORAGE=false
DISCORD_BOT_TOKEN=

STEAM_RETURN_URL=https://arma-stats.example.com/auth/steam/callback
STEAM_REALM=https://arma-stats.example.com/

SESSION_COOKIE_NAME=arma_attendance_session
SESSION_SECRET=change-this-session-secret
SESSION_TTL_HOURS=168
SESSION_SECURE=true
SESSION_SAME_SITE=None
CORS_ALLOWED_ORIGINS=https://tcwa3-galaxy-map.base44.app,https://preview-sandbox--6986a916d70fdb8646418766.base44.app
CORS_ALLOW_CREDENTIALS=true
OAUTH_ALLOWED_RETURN_ORIGINS=https://tcwa3-galaxy-map.base44.app,https://preview-sandbox--6986a916d70fdb8646418766.base44.app
JWT_AUTH_ENABLED=false
JWT_ISSUER=https://arma-stats.example.com
JWT_AUDIENCE=arma-attendance-web
JWT_SECRET=change-this-jwt-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
JWT_HANDOFF_TTL_SECONDS=120
CSRF_ENABLED=true
CSRF_TOKEN_TTL_MINUTES=120
SQUAD_ASSET_ROOT=/var/lib/arma-attendance/squad-assets
SQUAD_XML_DEFAULT_PICTURE=logo.paa
INITIAL_ADMIN_DISCORD_IDS=
ENABLE_TEST_AUTH=false
